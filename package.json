{
  "name": "infinite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"next dev\" \"node scripts/dev-server.mjs\"",
    "build": "prisma generate && npm run build:server && next build",
    "build:server": "tsc -p server/tsconfig.build.json",
    "start": "concurrently \"next start\" \"npm run start:server\"",
    "start:server": "npm run build:server && node .server-build/index.js",
    "lint": "eslint .",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "patch-package && prisma generate"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.2",
    "gsap": "^3.12.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "puppeteer": "^22.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-rnd": "^10.5.3",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.16.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/ws": "^8.0.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "^16.2.4",
    "patch-package": "^8.0.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.12",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
