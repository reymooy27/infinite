FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
COPY patches/ ./patches/
COPY prisma/ ./prisma/
COPY prisma.config.ts ./
ENV DATABASE_URL=postgresql://x:x@localhost:5432/x
ENV DIRECT_URL=postgresql://x:x@localhost:5432/x
RUN npm ci

COPY server/ ./server/

EXPOSE 3001
CMD ["npx", "tsx", "server/index.ts"]
