generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Connection {
  id                  Int      @id @default(autoincrement())
  name                String
  host                String
  port                Int      @default(22)
  username            String
  authType            String   @default("password") @map("auth_type")
  passwordEncrypted   String?  @map("password_encrypted")
  privateKeyEncrypted String?  @map("private_key_encrypted")
  createdAt           DateTime @default(now()) @map("created_at")
  userId              String   @default("local-user") @map("user_id")
  agentId             String?  @map("agent_id")

  @@map("connections")
}

model Layout {
  id        String   @id @default(cuid())
  userId    String   @default("local-user") @map("user_id")
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("layouts")
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  token     String   @unique
  userId    String   @default("local-user") @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agents")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  url       String
  userId    String   @default("local-user") @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bookmarks")
}

model Note {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  userId    String   @default("local-user") @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notes")
}

model Project {
  id              String   @id @default(cuid())
  name            String
  userId          String   @default("local-user") @map("user_id")
  directory       String?  @map("directory")
  canvasData      Json     @default("{\"windows\":[]}")
  canvasTransform Json?    @map("canvas_transform")
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model AIProviderKey {
  id              String   @id @default(cuid())
  provider        String
  apiKeyEncrypted String   @map("api_key_encrypted")
  userId          String   @default("local-user") @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, provider])
  @@map("ai_provider_keys")
}
