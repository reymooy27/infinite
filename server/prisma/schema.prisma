generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Connection {
  id                  Int      @id @default(autoincrement())
  name                String
  host                String
  port                Int      @default(22)
  username            String
  authType            String   @default("password") @map("auth_type")
  passwordEncrypted   String?  @map("password_encrypted")
  privateKeyEncrypted String?  @map("private_key_encrypted")
  createdAt           DateTime @default(now()) @map("created_at")
  userId              String   @default("local-user") @map("user_id")

  @@map("connections")
}

model Layout {
  id        String   @id @default(cuid())
  userId    String   @default("local-user") @map("user_id")
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("layouts")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  url       String
  userId    String   @default("local-user") @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bookmarks")
}

model Note {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  userId    String   @default("local-user") @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notes")
}

model Project {
  id              String   @id @default(cuid())
  name            String
  userId          String   @default("local-user") @map("user_id")
  directory       String?  @map("directory")
  canvasData      Json
  canvasTransform Json?    @map("canvas_transform")
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model AIProvider {
  id        String    @id @default(cuid())
  name      String
  baseUrl   String?   @map("base_url")
  userId    String    @default("local-user") @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  keys      AIKey[]

  @@unique([userId, name])
  @@map("ai_providers")
}

model AIKey {
  id              String      @id @default(cuid())
  label           String?     @default("")
  apiKeyEncrypted String      @map("api_key_encrypted")
  providerId      String      @map("provider_id")
  provider        AIProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  userId          String      @default("local-user") @map("user_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("ai_keys")
}
